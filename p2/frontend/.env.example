# ─── Backend API ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api

# ─── Gemini AI (optional — used for client-side AI features) ──────────────────
# Get your key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ─── Google OAuth (optional — disables Google sign-in button if missing) ──────
# Must match the GOOGLE_CLIENT_ID in backend/.env
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ─── Firebase (REQUIRED for login/signup to work) ─────────────────────────────
# Get ALL values from: Firebase Console → Project Settings → Your Apps → Web App
# https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
# Optional — only needed if you use Firebase Analytics
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
